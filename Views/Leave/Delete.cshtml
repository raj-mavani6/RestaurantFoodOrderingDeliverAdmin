@model RestaurantFoodOrderingDeliverAdmin.Models.Leave
@{
    ViewData["Title"] = "Delete Leave Request";
    var days = (Model.EndDate - Model.StartDate).Days + 1;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Leave")">Leave</a></li>
                    <li class="breadcrumb-item active">Delete Leave</li>
                </ol>
            </nav>
            <h2 class="page-heading text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Leave Request
            </h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Confirm Deletion</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Warning!</strong> You are about to delete this leave request. This action cannot be undone.
                    </div>

                    <!-- Leave Info -->
                    <div class="row mb-4">
                        <div class="col-md-3 text-center">
                            <i class="fas fa-calendar-minus fa-5x text-danger"></i>
                        </div>
                        <div class="col-md-9">
                            <h4>Leave Request #@Model.LeaveId</h4>
                            @if (Model.DeliveryUser != null)
                            {
                                <p class="mb-1">
                                    <i class="fas fa-user me-2"></i>
                                    <strong>@Model.DeliveryUser.FullName</strong>
                                </p>
                            }
                            <p class="mb-1">
                                <i class="fas fa-calendar me-2"></i>
                                @Model.StartDate.ToString("dd MMM yyyy") - @Model.EndDate.ToString("dd MMM yyyy")
                                <span class="badge bg-dark ms-2">@days Day(s)</span>
                            </p>
                            <hr>
                            <div class="row">
                                <div class="col-4">
                                    <strong>Type</strong><br>
                                    <span class="badge bg-info">@Model.LeaveType</span>
                                </div>
                                <div class="col-4">
                                    <strong>Status</strong><br>
                                    @switch (Model.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-warning">Pending</span>
                                            break;
                                        case "Approved":
                                            <span class="badge bg-success">Approved</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                    }
                                </div>
                                <div class="col-4">
                                    <strong>Applied</strong><br>
                                    @Model.AppliedDate.ToString("dd MMM")
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" action="@Url.Action("Delete", "Leave", new { id = Model.LeaveId })">
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Leave")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Delete Permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
