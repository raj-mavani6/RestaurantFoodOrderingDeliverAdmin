@{
    ViewData["Title"] = "Add Earning";
    var users = ViewBag.DeliveryUsers as IEnumerable<RestaurantFoodOrderingDeliverAdmin.Models.DeliveryUser>;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Earnings")">Earnings</a></li>
                    <li class="breadcrumb-item active">Add Earning</li>
                </ol>
            </nav>
            <h2 class="page-heading">
                <i class="fas fa-plus-circle me-2"></i>Add New Earning
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Earnings")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <form method="post" action="@Url.Action("Create", "Earnings")">
        <div class="row">
            <div class="col-md-8">
                <!-- Delivery Partner -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Select Delivery Partner</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Delivery Partner <span class="text-danger">*</span></label>
                            <select class="form-select" name="DeliveryUserId" required>
                                <option value="">-- Select Delivery Partner --</option>
                                @if (users != null)
                                {
                                    @foreach (var user in users)
                                    {
                                        <option value="@user.DeliveryUserId">@user.FullName - @(user.Phone ?? "N/A")</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Earning Details -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-rupee-sign me-2"></i>Earning Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Delivery Fee (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="DeliveryFee" value="0" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tip Amount (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="TipAmount" value="0" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bonus (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Bonus" value="0" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Incentive (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Incentive" value="0" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deduction (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Deduction" value="0" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Earning Type</label>
                                <select class="form-select" name="EarningType">
                                    <option value="Delivery">Delivery</option>
                                    <option value="Bonus">Bonus</option>
                                    <option value="Incentive">Incentive</option>
                                    <option value="Adjustment">Adjustment</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Info -->
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Additional Info</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" rows="2" placeholder="Add description..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payment Status</label>
                            <select class="form-select" name="PaymentStatus">
                                <option value="Pending">Pending</option>
                                <option value="Paid">Paid</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <button type="submit" class="btn btn-success w-100 mb-2">
                            <i class="fas fa-save me-2"></i>Create Earning
                        </button>
                        <a href="@Url.Action("Index", "Earnings")" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
