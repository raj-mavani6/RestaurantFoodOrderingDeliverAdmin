@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryEarning
@{
    ViewData["Title"] = "Delete Earning";
    var total = Model.DeliveryFee + Model.TipAmount + Model.Bonus + Model.Incentive - Model.Deduction;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Earnings")">Earnings</a></li>
                    <li class="breadcrumb-item active">Delete Earning</li>
                </ol>
            </nav>
            <h2 class="page-heading text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Earning
            </h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Confirm Deletion</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Warning!</strong> You are about to delete this earning record. This action cannot be undone.
                    </div>

                    <!-- Earning Info -->
                    <div class="row mb-4">
                        <div class="col-md-3 text-center">
                            <i class="fas fa-wallet fa-5x text-danger"></i>
                        </div>
                        <div class="col-md-9">
                            <h4>Earning #@Model.EarningId</h4>
                            @if (Model.DeliveryUser != null)
                            {
                                <p class="mb-1">
                                    <i class="fas fa-user me-2"></i>
                                    <strong>@Model.DeliveryUser.FullName</strong>
                                </p>
                            }
                            <p class="mb-1">
                                <i class="fas fa-calendar me-2"></i>
                                @Model.EarningDate.ToString("dd MMM yyyy")
                            </p>
                            <hr>
                            <div class="row">
                                <div class="col-4">
                                    <strong>Total</strong><br>
                                    <span class="text-success fs-5">₹@total.ToString("N2")</span>
                                </div>
                                <div class="col-4">
                                    <strong>Type</strong><br>
                                    @(Model.EarningType ?? "Delivery")
                                </div>
                                <div class="col-4">
                                    <strong>Status</strong><br>
                                    @if (Model.PaymentStatus == "Paid")
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" action="@Url.Action("Delete", "Earnings", new { id = Model.EarningId })">
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Earnings")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Delete Permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
