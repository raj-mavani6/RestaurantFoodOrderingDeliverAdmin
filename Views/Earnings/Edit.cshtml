@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryEarning
@{
    ViewData["Title"] = "Edit Earning";
    var users = ViewBag.DeliveryUsers as IEnumerable<RestaurantFoodOrderingDeliverAdmin.Models.DeliveryUser>;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Earnings")">Earnings</a></li>
                    <li class="breadcrumb-item active">Edit Earning #@Model.EarningId</li>
                </ol>
            </nav>
            <h2 class="page-heading">
                <i class="fas fa-edit me-2"></i>Edit Earning #@Model.EarningId
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Earnings")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <form method="post" action="@Url.Action("Edit", "Earnings")">
        <input type="hidden" name="EarningId" value="@Model.EarningId" />
        
        <div class="row">
            <div class="col-md-8">
                <!-- Delivery Partner -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Delivery Partner</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Delivery Partner <span class="text-danger">*</span></label>
                            <select class="form-select" name="DeliveryUserId" required>
                                <option value="">-- Select Delivery Partner --</option>
                                @if (users != null)
                                {
                                    @foreach (var user in users)
                                    {
                                        if (user.DeliveryUserId == Model.DeliveryUserId)
                                        {
                                            <option value="@user.DeliveryUserId" selected>@user.FullName - @(user.Phone ?? "N/A")</option>
                                        }
                                        else
                                        {
                                            <option value="@user.DeliveryUserId">@user.FullName - @(user.Phone ?? "N/A")</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Earning Details -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-rupee-sign me-2"></i>Earning Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Delivery Fee (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="DeliveryFee" value="@Model.DeliveryFee" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tip Amount (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="TipAmount" value="@Model.TipAmount" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bonus (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Bonus" value="@Model.Bonus" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Incentive (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Incentive" value="@Model.Incentive" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deduction (₹)</label>
                                <input type="number" step="0.01" class="form-control" name="Deduction" value="@Model.Deduction" min="0">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Earning Type</label>
                                <select class="form-select" name="EarningType">
                                    @{
                                        var types = new[] { "Delivery", "Bonus", "Incentive", "Adjustment" };
                                    }
                                    @foreach (var type in types)
                                    {
                                        if (type == Model.EarningType)
                                        {
                                            <option value="@type" selected>@type</option>
                                        }
                                        else
                                        {
                                            <option value="@type">@type</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Info -->
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Additional Info</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" rows="2">@Model.Description</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payment Status</label>
                            <select class="form-select" name="PaymentStatus">
                                @{
                                    var statuses = new[] { "Pending", "Paid" };
                                }
                                @foreach (var status in statuses)
                                {
                                    if (status == Model.PaymentStatus)
                                    {
                                        <option value="@status" selected>@status</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-calculator me-2"></i>Current Total</h5>
                    </div>
                    <div class="card-body text-center">
                        @{
                            var total = Model.DeliveryFee + Model.TipAmount + Model.Bonus + Model.Incentive - Model.Deduction;
                        }
                        <h2 class="text-success">₹@total.ToString("N2")</h2>
                    </div>
                </div>
                
                <div class="card">
                    <div class="card-body">
                        <button type="submit" class="btn btn-success w-100 mb-2">
                            <i class="fas fa-save me-2"></i>Update Earning
                        </button>
                        <a href="@Url.Action("Index", "Earnings")" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
