@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryOrder
@{
    ViewData["Title"] = "Delete Order";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Orders")">Orders</a></li>
                    <li class="breadcrumb-item active">Delete Order</li>
                </ol>
            </nav>
            <h2 class="page-heading text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Order
            </h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Confirm Deletion</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Warning!</strong> You are about to delete this order. This action cannot be undone.
                    </div>

                    <!-- Order Info -->
                    <div class="row mb-4">
                        <div class="col-md-3 text-center">
                            <i class="fas fa-shopping-cart fa-5x text-danger"></i>
                        </div>
                        <div class="col-md-9">
                            <h4>Order #@Model.DeliveryOrderId</h4>
                            <p class="mb-1">
                                <i class="fas fa-user me-2"></i>
                                <strong>@(Model.CustomerName ?? "Unknown Customer")</strong>
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-phone me-2"></i>
                                @(Model.CustomerPhone ?? "N/A")
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-map-marker-alt me-2"></i>
                                @(Model.DeliveryAddress ?? "N/A")
                            </p>
                            <hr>
                            <div class="row">
                                <div class="col-4">
                                    <strong>Total</strong><br>
                                    <span class="text-success">₹@Model.TotalAmount.ToString("N2")</span>
                                </div>
                                <div class="col-4">
                                    <strong>Status</strong><br>
                                    @switch (Model.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-warning">Pending</span>
                                            break;
                                        case "Delivered":
                                            <span class="badge bg-success">Delivered</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-danger">Cancelled</span>
                                            break;
                                        default:
                                            <span class="badge bg-info">@Model.Status</span>
                                            break;
                                    }
                                </div>
                                <div class="col-4">
                                    <strong>Partner</strong><br>
                                    @if (Model.DeliveryUser != null)
                                    {
                                        <span>@Model.DeliveryUser.FullName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" action="@Url.Action("Delete", "Orders", new { id = Model.DeliveryOrderId })">
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Delete Permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
