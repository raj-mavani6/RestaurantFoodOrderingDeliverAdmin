@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryOrder
@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Orders")">Orders</a></li>
                    <li class="breadcrumb-item active">Order #@Model.DeliveryOrderId</li>
                </ol>
            </nav>
            <h2 class="page-heading">
                <i class="fas fa-shopping-cart me-2"></i>Order Details
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Edit", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-success me-2">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Order Info -->
        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header bg-primary-custom text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Order Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Order ID</label>
                            <p class="fw-bold fs-5">#@Model.DeliveryOrderId</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Status</label>
                            <p>
                                @switch (Model.Status)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning fs-6">Pending</span>
                                        break;
                                    case "Assigned":
                                        <span class="badge bg-info fs-6">Assigned</span>
                                        break;
                                    case "Picked Up":
                                        <span class="badge bg-primary fs-6">Picked Up</span>
                                        break;
                                    case "Delivered":
                                        <span class="badge bg-success fs-6">Delivered</span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge bg-danger fs-6">Cancelled</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary fs-6">@Model.Status</span>
                                        break;
                                }
                            </p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Order Time</label>
                            <p class="fw-bold"><i class="fas fa-calendar me-2"></i>@Model.OrderTime.ToString("dd MMM yyyy, hh:mm tt")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Assigned Time</label>
                            <p class="fw-bold"><i class="fas fa-clock me-2"></i>@Model.AssignedTime.ToString("dd MMM yyyy, hh:mm tt")</p>
                        </div>
                        @if (Model.PickupTime.HasValue)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="text-muted">Pickup Time</label>
                                <p class="fw-bold"><i class="fas fa-box me-2"></i>@Model.PickupTime.Value.ToString("dd MMM yyyy, hh:mm tt")</p>
                            </div>
                        }
                        @if (Model.DeliveredTime.HasValue)
                        {
                            <div class="col-md-6 mb-3">
                                <label class="text-muted">Delivered Time</label>
                                <p class="fw-bold"><i class="fas fa-check-circle me-2"></i>@Model.DeliveredTime.Value.ToString("dd MMM yyyy, hh:mm tt")</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Customer Info -->
            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Customer Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Customer Name</label>
                            <p class="fw-bold"><i class="fas fa-user me-2"></i>@(Model.CustomerName ?? "N/A")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Phone</label>
                            <p class="fw-bold"><i class="fas fa-phone me-2"></i>@(Model.CustomerPhone ?? "N/A")</p>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="text-muted">Delivery Address</label>
                            <p class="fw-bold"><i class="fas fa-map-marker-alt me-2"></i>@(Model.DeliveryAddress ?? "N/A")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                        {
                            <div class="col-12">
                                <label class="text-muted">Special Instructions</label>
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-circle me-2"></i>@Model.SpecialInstructions
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-4">
            <!-- Payment Info -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-rupee-sign me-2"></i>Payment Details</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Order Amount</span>
                        <strong>₹@Model.TotalAmount.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Delivery Fee</span>
                        <strong>₹@Model.DeliveryFee.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tip</span>
                        <strong>₹@Model.TipAmount.ToString("N2")</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">Total</span>
                        <strong class="text-success fs-5">₹@((Model.TotalAmount + Model.DeliveryFee + Model.TipAmount).ToString("N2"))</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>Payment Method</span>
                        <span class="badge bg-secondary">@(Model.PaymentMethod ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span>Payment Status</span>
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">@(Model.PaymentStatus ?? "Pending")</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Delivery Partner -->
            <div class="card mb-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-motorcycle me-2"></i>Delivery Partner</h5>
                </div>
                <div class="card-body text-center">
                    @if (Model.DeliveryUser != null)
                    {
                        <i class="fas fa-user-circle fa-4x text-primary mb-2"></i>
                        <h5>@Model.DeliveryUser.FullName</h5>
                        <p class="text-muted mb-1"><i class="fas fa-phone me-1"></i>@(Model.DeliveryUser.Phone ?? "N/A")</p>
                        <p class="text-muted"><i class="fas fa-envelope me-1"></i>@(Model.DeliveryUser.Email ?? "N/A")</p>
                    }
                    else
                    {
                        <i class="fas fa-user-times fa-4x text-muted mb-2"></i>
                        <h5 class="text-muted">Not Assigned</h5>
                        <a href="@Url.Action("AssignOrder", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-primary mt-2">
                            <i class="fas fa-user-plus me-2"></i>Assign Now
                        </a>
                    }
                </div>
            </div>

            <!-- Customer Rating -->
            @if (Model.CustomerRating.HasValue)
            {
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-star me-2"></i>Customer Feedback</h5>
                    </div>
                    <div class="card-body text-center">
                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Model.CustomerRating.Value)
                                {
                                    <i class="fas fa-star text-warning fs-4"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-warning fs-4"></i>
                                }
                            }
                        </div>
                        <p class="fw-bold">@Model.CustomerRating / 5</p>
                        @if (!string.IsNullOrEmpty(Model.CustomerFeedback))
                        {
                            <p class="text-muted">"@Model.CustomerFeedback"</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="mb-3"><i class="fas fa-cogs me-2"></i>Quick Actions</h5>
                    <a href="@Url.Action("Edit", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-success me-2">
                        <i class="fas fa-edit me-2"></i>Edit Order
                    </a>
                    @if (Model.DeliveryUser == null)
                    {
                        <a href="@Url.Action("AssignOrder", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-info me-2">
                            <i class="fas fa-user-plus me-2"></i>Assign Delivery Partner
                        </a>
                    }
                    <a href="@Url.Action("Delete", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Delete Order
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
