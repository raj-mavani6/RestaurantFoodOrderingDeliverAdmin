@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryOrder
@{
    ViewData["Title"] = "Edit Order";
    var users = ViewBag.DeliveryUsers as IEnumerable<RestaurantFoodOrderingDeliverAdmin.Models.DeliveryUser>;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Orders")">Orders</a></li>
                    <li class="breadcrumb-item active">Edit Order #@Model.DeliveryOrderId</li>
                </ol>
            </nav>
            <h2 class="page-heading">
                <i class="fas fa-edit me-2"></i>Edit Order #@Model.DeliveryOrderId
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <form method="post" action="@Url.Action("Edit", "Orders")">
        <input type="hidden" name="DeliveryOrderId" value="@Model.DeliveryOrderId" />
        <input type="hidden" name="OrderId" value="@Model.OrderId" />
        <input type="hidden" name="DeliveryUserId" value="@Model.DeliveryUserId" />
        <input type="hidden" name="OrderTime" value="@Model.OrderTime" />
        <input type="hidden" name="AssignedTime" value="@Model.AssignedTime" />
        <input type="hidden" name="TotalAmount" value="@Model.TotalAmount" />
        <input type="hidden" name="Distance" value="@Model.Distance" />

        <div class="row">
            <div class="col-md-8">
                <!-- Customer Info -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Customer Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Name</label>
                                <input type="text" class="form-control" name="CustomerName" value="@Model.CustomerName">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Phone</label>
                                <input type="text" class="form-control" name="CustomerPhone" value="@Model.CustomerPhone">
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Delivery Address</label>
                                <textarea class="form-control" name="DeliveryAddress" rows="2">@Model.DeliveryAddress</textarea>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Special Instructions</label>
                                <textarea class="form-control" name="SpecialInstructions" rows="2">@Model.SpecialInstructions</textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order Status -->
                <div class="card mb-3">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="fas fa-tasks me-2"></i>Order Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Order Status <span class="text-danger">*</span></label>
                                <select class="form-select" name="Status" required>
                                    @{
                                        var statuses = new[] { "Pending", "Assigned", "Picked Up", "In Transit", "Delivered", "Cancelled" };
                                    }
                                    @foreach (var status in statuses)
                                    {
                                        if (status == Model.Status)
                                        {
                                            <option value="@status" selected>@status</option>
                                        }
                                        else
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Payment Status</label>
                                <select class="form-select" name="PaymentStatus">
                                    @{
                                        var paymentStatuses = new[] { "Pending", "Paid", "Failed", "Refunded" };
                                    }
                                    @foreach (var ps in paymentStatuses)
                                    {
                                        if (ps == Model.PaymentStatus)
                                        {
                                            <option value="@ps" selected>@ps</option>
                                        }
                                        else
                                        {
                                            <option value="@ps">@ps</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Delivery Notes -->
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Delivery Notes</h5>
                    </div>
                    <div class="card-body">
                        <textarea class="form-control" name="DeliveryNotes" rows="3" placeholder="Add any delivery notes...">@Model.DeliveryNotes</textarea>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-md-4">
                <!-- Payment Info -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-rupee-sign me-2"></i>Payment Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Delivery Fee (₹)</label>
                            <input type="number" step="0.01" class="form-control" name="DeliveryFee" value="@Model.DeliveryFee">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tip Amount (₹)</label>
                            <input type="number" step="0.01" class="form-control" name="TipAmount" value="@Model.TipAmount">
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <span>Order Total</span>
                            <strong>₹@Model.TotalAmount.ToString("N2")</strong>
                        </div>
                    </div>
                </div>

                <!-- Assigned Partner -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-motorcycle me-2"></i>Delivery Partner</h5>
                    </div>
                    <div class="card-body text-center">
                        @if (Model.DeliveryUser != null)
                        {
                            <i class="fas fa-user-circle fa-3x text-primary mb-2"></i>
                            <h6>@Model.DeliveryUser.FullName</h6>
                            <p class="text-muted small">@(Model.DeliveryUser.Phone ?? "N/A")</p>
                        }
                        else
                        {
                            <i class="fas fa-user-times fa-3x text-muted mb-2"></i>
                            <p class="text-muted">Not Assigned</p>
                            <a href="@Url.Action("AssignOrder", "Orders", new { id = Model.DeliveryOrderId })" class="btn btn-sm btn-info">
                                <i class="fas fa-user-plus me-1"></i>Assign
                            </a>
                        }
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="card">
                    <div class="card-body">
                        <button type="submit" class="btn btn-success w-100 mb-2">
                            <i class="fas fa-save me-2"></i>Update Order
                        </button>
                        <a href="@Url.Action("Index", "Orders")" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
