@model IEnumerable<RestaurantFoodOrderingDeliverAdmin.Models.DeliveryEarning>
@{
    ViewData["Title"] = "Earnings Report";
    
    var totalEarnings = Model.Sum(e => e.DeliveryFee + e.TipAmount + e.Bonus + e.Incentive - e.Deduction);
    var totalTips = Model.Sum(e => e.TipAmount);
    var totalBonuses = Model.Sum(e => e.Bonus + e.Incentive);
}

<div class="container-fluid py-4">
     <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Report")">Reports</a></li>
                    <li class="breadcrumb-item active">Earnings</li>
                </ol>
            </nav>
            <h2 class="page-heading"><i class="fas fa-wallet me-2"></i>Earnings & Payouts</h2>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
             <div class="report-stat-card success">
                <div class="report-icon bg-light-success">
                    <i class="fas fa-rupee-sign"></i>
                </div>
                <div class="report-content">
                    <h6>Total Payouts</h6>
                    <h3>₹@totalEarnings.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
             <div class="report-stat-card info">
                <div class="report-icon bg-light-info">
                    <i class="fas fa-hand-holding-usd"></i>
                </div>
                <div class="report-content">
                    <h6>Total Tips</h6>
                    <h3>₹@totalTips.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
             <div class="report-stat-card warning">
                <div class="report-icon bg-light-warning">
                    <i class="fas fa-gift"></i>
                </div>
                <div class="report-content">
                    <h6>Bonuses & Incentives</h6>
                    <h3>₹@totalBonuses.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Earnings Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
             <h5 class="card-title mb-0">Payout History</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Partner</th>
                            <th>Delivery Fee</th>
                            <th>Tips</th>
                            <th>Incentives</th>
                            <th>Deductions</th>
                            <th>Net Earning</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var net = item.DeliveryFee + item.TipAmount + item.Bonus + item.Incentive - item.Deduction;
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                         <div class="user-avatar-small">
                                            @item.DeliveryUser?.FullName.Substring(0,1)
                                        </div>
                                        <span>@(item.DeliveryUser?.FullName ?? "Unknown")</span>
                                    </div>
                                </td>
                                <td>₹@item.DeliveryFee.ToString("N2")</td>
                                <td>₹@item.TipAmount.ToString("N2")</td>
                                <td class="text-success">+₹@((item.Bonus + item.Incentive).ToString("N2"))</td>
                                <td class="text-danger">-₹@item.Deduction.ToString("N2")</td>
                                <td class="fw-bold">₹@net.ToString("N2")</td>
                                <td>
                                    <span class="badge @(item.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">
                                        @item.PaymentStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
