@model IEnumerable<RestaurantFoodOrderingDeliverAdmin.Models.DeliveryUser>
@{
    ViewData["Title"] = "Delivery Users Report";
    var activeCount = ViewBag.ActiveUsers;
    var inactiveCount = ViewBag.InactiveUsers;
    var avgRating = ViewBag.AvgRating;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Report")">Reports</a></li>
                    <li class="breadcrumb-item active">Delivery Users</li>
                </ol>
            </nav>
            <h2 class="page-heading"><i class="fas fa-users me-2"></i>Delivery Users Insights</h2>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
             <div class="report-stat-card primary">
                <div class="report-icon bg-light-primary">
                    <i class="fas fa-user-friends"></i>
                </div>
                <div class="report-content">
                    <h6>Total Users</h6>
                    <h3>@ViewBag.TotalUsers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
             <div class="report-stat-card success">
                <div class="report-icon bg-light-success">
                    <i class="fas fa-user-check"></i>
                </div>
                <div class="report-content">
                    <h6>Active Users</h6>
                    <h3>@activeCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
             <div class="report-stat-card warning">
                <div class="report-icon bg-light-warning">
                    <i class="fas fa-star"></i>
                </div>
                <div class="report-content">
                    <h6>Avg Rating</h6>
                    <h3>@Convert.ToDouble(avgRating).ToString("0.0")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mb-4">
        <div class="col-md-5">
            <div class="chart-container">
                 <div class="chart-header">
                    <h5 class="chart-title">User Status Distribution</h5>
                </div>
                <div class="card-body">
                    <canvas id="userStatusChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-7">
             <!-- Placeholder for another chart or detailed info if needed -->
             <div class="card h-100 border-0 shadow-sm">
                 <div class="card-header bg-white border-0">
                     <h5 class="chart-title">Top Rated Partners</h5>
                 </div>
                 <div class="card-body">
                     <div class="table-responsive">
                         <table class="table table-borderless align-middle">
                             <thead>
                                 <tr>
                                     <th>Partner</th>
                                     <th>Rating</th>
                                     <th>Deliveries</th>
                                 </tr>
                             </thead>
                             <tbody>
                                 @foreach(var user in Model.OrderByDescending(u => u.Rating).Take(5))
                                 {
                                     <tr>
                                         <td>
                                             <div class="d-flex align-items-center">
                                                 <div class="user-avatar-small">
                                                    @user.FullName.Substring(0,1)
                                                 </div>
                                                 <span>@user.FullName</span>
                                             </div>
                                         </td>
                                         <td><span class="badge bg-warning text-dark"><i class="fas fa-star me-1"></i>@user.Rating</span></td>
                                         <td>@user.TotalDeliveries</td>
                                     </tr>
                                 }
                             </tbody>
                         </table>
                     </div>
                 </div>
             </div>
        </div>
    </div>

    <!-- Detailed List -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
             <h5 class="card-title mb-0">All Delivery Users</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Phone</th>
                            <th>City</th>
                            <th>Vehicle</th>
                            <th>Status</th>
                            <th>Joined Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.FullName</td>
                                <td>@item.Phone</td>
                                <td>@item.City</td>
                                <td>@item.VehicleType <small class="text-muted">(@item.VehicleNumber)</small></td>
                                <td>
                                    @if(item.Status == "Active") { <span class="badge bg-success">Active</span> }
                                    else { <span class="badge bg-secondary">Inactive</span> }
                                </td>
                                <td>-</td> 
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize User Status Chart
            initDoughnutChart(
                'userStatusChart',
                ['Active', 'Inactive'],
                [@activeCount, @inactiveCount],
                ['#198754', '#6c757d']
            );
        });
    </script>
}
