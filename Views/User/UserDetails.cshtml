@model RestaurantFoodOrderingDeliverAdmin.Models.DeliveryUser
@{
    ViewData["Title"] = "User Details - " + Model.FullName;
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("DeliveryUsers", "User")">Delivery Users</a></li>
                    <li class="breadcrumb-item active">User Details</li>
                </ol>
            </nav>
            <h2 class="page-heading">
                <i class="fas fa-user me-2"></i>User Details
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("UserEdit", "User", new { id = Model.DeliveryUserId })" class="btn btn-success me-2">
                <i class="fas fa-edit me-2"></i>Edit User
            </a>
            <a href="@Url.Action("DeliveryUsers", "User")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <!-- User Profile Card -->
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="user-profile-avatar mb-3">
                        <i class="fas fa-user-circle fa-5x text-primary"></i>
                    </div>
                    <h4>@Model.FullName</h4>
                    <p class="text-muted">@Model.Email</p>
                    @if (Model.Status == "Active" && Model.IsActive)
                    {
                        <span class="badge bg-success fs-6">Active</span>
                    }
                    else if (Model.Status == "On Leave")
                    {
                        <span class="badge bg-warning fs-6">On Leave</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Inactive</span>
                    }
                    
                    <hr>
                    
                    <div class="row text-center">
                        <div class="col-6">
                            <h5 class="text-primary">@Model.TotalDeliveries</h5>
                            <small class="text-muted">Deliveries</small>
                        </div>
                        <div class="col-6">
                            <h5 class="text-success">₹@Model.TotalEarnings.ToString("N0")</h5>
                            <small class="text-muted">Earnings</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Information -->
        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header bg-primary-custom text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Full Name</label>
                            <p class="fw-bold">@Model.FullName</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Email</label>
                            <p class="fw-bold">@Model.Email</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Phone</label>
                            <p class="fw-bold"><i class="fas fa-phone me-2"></i>@Model.Phone</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">City</label>
                            <p class="fw-bold">@(Model.City ?? "N/A")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Permanent Address</label>
                            <p class="fw-bold">@(Model.PermanentAddress ?? "N/A")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Current Address</label>
                            <p class="fw-bold">@(Model.CurrentAddress ?? "N/A")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Vehicle Information -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-motorcycle me-2"></i>Vehicle Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Vehicle Type</label>
                            <p class="fw-bold">@(Model.VehicleType ?? "N/A")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Vehicle Number</label>
                            <p class="fw-bold">@(Model.VehicleNumber ?? "N/A")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Information -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-user-cog me-2"></i>Account Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Join Date</label>
                            <p class="fw-bold">@Model.JoinDate.ToString("dd MMM yyyy")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Last Login</label>
                            <p class="fw-bold">@(Model.LastLoginDate?.ToString("dd MMM yyyy HH:mm") ?? "Never")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Status</label>
                            <p class="fw-bold">@Model.Status</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted">Account Active</label>
                            <p class="fw-bold">
                                @if (Model.IsActive)
                                {
                                    <span class="text-success"><i class="fas fa-check-circle"></i> Yes</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="fas fa-times-circle"></i> No</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="mb-3"><i class="fas fa-cogs me-2"></i>Quick Actions</h5>
                    <a href="@Url.Action("UserEdit", "User", new { id = Model.DeliveryUserId })" class="btn btn-success me-2">
                        <i class="fas fa-edit me-2"></i>Edit User
                    </a>
                    @if (Model.IsActive)
                    {
                        <form action="@Url.Action("DeactivateUser", "User")" method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Model.DeliveryUserId" />
                            <button type="submit" class="btn btn-warning me-2">
                                <i class="fas fa-ban me-2"></i>Deactivate
                            </button>
                        </form>
                    }
                    else
                    {
                        <form action="@Url.Action("ActivateUser", "User")" method="post" style="display: inline;">
                            <input type="hidden" name="id" value="@Model.DeliveryUserId" />
                            <button type="submit" class="btn btn-primary me-2">
                                <i class="fas fa-check me-2"></i>Activate
                            </button>
                        </form>
                    }
                    <a href="@Url.Action("UserDelete", "User", new { id = Model.DeliveryUserId })" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Delete User
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
